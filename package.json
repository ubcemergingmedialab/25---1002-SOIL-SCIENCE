{
  "name": "soil-science",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/viewer",
    "apps/admin",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev:viewer",
    "dev:viewer": "vite --config apps/viewer/vite.config.ts",
    "dev:admin": "vite --config apps/admin/vite.config.ts",
    "build": "npm run build:viewer && npm run build:admin",
    "build:viewer": "tsc -b && vite build --config apps/viewer/vite.config.ts",
    "build:admin": "tsc -b && vite build --config apps/admin/vite.config.ts",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview:viewer": "vite preview --config apps/viewer/vite.config.ts",
    "preview:admin": "vite preview --config apps/admin/vite.config.ts"
  },
  "dependencies": {
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "aws-amplify": "^6.16.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-glsl": "^1.5.4"
  }
}
